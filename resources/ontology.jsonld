  {
    "@id": "http://data.quality-link.eu/ontology/v1#",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology"
    ],
    "http://creativecommons.org/ns#attributionName": [
      {
        "@language": "en",
        "@value": "QualityLink project"
      }
    ],
    "http://creativecommons.org/ns#attributionURL": [
      {
        "@id": "https://quality-link.eu/"
      }
    ],
    "http://purl.org/dc/terms/abstract": [
      {
        "@language": "en",
        "@value": "The QualityLink ontology and application profile build on the European Learning Model (ELM). They defines additional classes and properties to describe things not currently covered in ELM."
      }
    ],
    "http://purl.org/dc/terms/created": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2025-02-13"
      }
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@language": "en",
        "@value": "The QualityLink ontology extends the European Learning Model (ELM) ontology by additional classes and properties required in the context of the QualityLink project.\n\nThe additional classes and properties describe things not currently covered in ELM, including certain quality indicators with relevance for the project.\n\nQualityLink further defines an application profile defined as SHACL constraints, which are based on the ELM Learning Opportunities and Qualifications (LOQ) application profile. The application profile is used by the QualityLink pilot aggregator. The QualityLink profile only adds optional properties to the ELM profile, no required ones.\n\nThe profile references the [ELM controlled vocabularies](https://op.europa.eu/en/web/eu-vocabularies/europasstables) published by the EU."
      }
    ],
    "http://purl.org/dc/terms/license": [
      {
        "@id": "https://creativecommons.org/licenses/by/4.0/"
      }
    ],
    "http://purl.org/dc/terms/modified": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#date",
        "@value": "2025-11-28"
      }
    ],
    "http://purl.org/dc/terms/publisher": [
      {
        "@id": "https://quality-link.eu/"
      }
    ],
    "http://purl.org/dc/terms/title": [
      {
        "@language": "en",
        "@value": "QualityLink Ontology and Application Profile"
      }
    ],
    "http://usefulinc.com/ns/doap#repository": [
      {
        "@id": "https://github.com/Knowledge-Innovation-Centre/quality-link-specs"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "QualityLink"
      }
    ],
    "http://www.w3.org/2002/07/owl#imports": [
      {
        "@id": "http://data.europa.eu/snb/model/ontology/"
      }
    ],
    "http://www.w3.org/2002/07/owl#versionInfo": [
      {
        "@value": "1.1.0-alpha"
      }
    ],
    "http://www.w3.org/ns/dcat#distribution": [
      {
